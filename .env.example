# Formspree submit target: paste the full "form endpoint" URL from Formspree, OR only the /f/… slug.
# Examples: https://formspree.io/p/PROJECT_ID/f/contact   OR   xnqwkgep
NEXT_PUBLIC_FORMSPREE_ID=

# Optional: Formspree CLI (`npm run formspree:deploy`). Never use NEXT_PUBLIC_ here.
FORMSPREE_DEPLOY_KEY=

# Optional: your Formspree project / product id (reference only; the app does not read this)
# FORMSPREE_PRODUCT_ID=
